# Pastel Radar — flight tracker

# No keys are required to use airplanes.live, adsb.fi, or adsbdb — they are
# public, key-less public endpoints. You may set a custom origin for the
# ADSBDB referer header if you self-host and want to be polite.

# App
NEXT_PUBLIC_APP_NAME=Pastel Radar

# Live data refresh interval in milliseconds (default 8000)
NEXT_PUBLIC_REFRESH_INTERVAL_MS=8000

# Max time before cached metadata is considered stale (default 6 hours in ms)
METADATA_TTL_MS=21600000

# Aircraft radius from map center (nm) when viewport-bounded fetches aren't
# available — used as a fallback
NEXT_DEFAULT_RADIUS_NM=250

# Optional: opaque API base overrides (leave blank for defaults)
AIRPLANES_LIVE_BASE=
ADSB_FI_BASE=
ADSBDB_BASE=
